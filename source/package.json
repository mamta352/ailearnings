{
  "scripts": {
    "generate:content-data": "node scripts/generate-content-data.js",
    "build:js": "node scripts/generate-content-data.js && cat src/icons.jsx src/content-data.js app.jsx > ../dist/combined.jsx && babel ../dist/combined.jsx --presets @babel/preset-react -o ../dist/app.js && terser ../dist/app.js -o ../dist/app.js --compress --mangle && rm ../dist/combined.jsx",
    "build:css": "tailwindcss -i tailwind.css -o ../dist/app.css --minify",
    "build:inline": "node scripts/inline.js",
    "build": "npm run build:js && npm run build:css && npm run build:inline",
    "generate": "npm run build && node scripts/generate-static.js",
    "generate:blog": "node scripts/generate-blog.js",
    "generate:projects": "node scripts/generate-projects.js",
    "generate:paths": "node scripts/generate-paths.js",
    "generate:all": "npm run build && npm run generate:blog && npm run generate:projects && npm run generate:paths && node scripts/generate-static.js",
    "generate:diagrams": "node scripts/generate-diagrams.js",
    "generate:excalidraw": "node scripts/generate-excalidraw.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:og": "node scripts/generate-og-image.js",
    "deploy": "cd .. && git add -A && git diff --cached --quiet && echo 'nothing to commit' || git commit -m 'build: auto-deploy' && git push origin main",
    "dev": "chokidar '**/*.tsx' '**/*.jsx' 'tailwind.css' 'tailwind.config.js' 'scripts/inline.js' --ignore 'node_modules/**' --debounce 500 -c 'npm run build && npm run deploy'",
    "seo:index": "node scripts/request-indexing.js",
    "seo:index:blog": "node scripts/request-indexing.js --blog",
    "seo:index:ranked": "node scripts/request-indexing.js --ranked",
    "seo:index:dry": "node scripts/request-indexing.js --dry-run",
    "seo:index:ranked:dry": "node scripts/request-indexing.js --ranked --dry-run",
    "seo:audit": "node scripts/audit-pages.js --days=90",
    "seo:audit:30": "node scripts/audit-pages.js --days=30",
    "seo:export": "node scripts/export-page-metadata.js --days=90",
    "seo:noindex": "node scripts/create-noindex-pages.js",
    "seo:ctr": "node scripts/analyze-ctr-trends.js --days=90",
    "seo:ctr:30": "node scripts/analyze-ctr-trends.js --days=30",
    "seo:ctr:all": "node scripts/analyze-ctr-trends.js --days=90 --all",
    "seo:master": "node scripts/generate-seo-master.js",
    "seo:master:fast": "node scripts/generate-seo-master.js --no-gsc",
    "seo:apply": "node scripts/apply-seo-pages.js",
    "seo:apply:dry": "node scripts/apply-seo-pages.js --dry-run"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@tailwindcss/cli": "^4.2.1",
    "chokidar-cli": "^3.0.0",
    "google-auth-library": "^10.6.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "puppeteer": "^24.38.0",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.0"
  }
}
