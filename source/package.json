{
  "scripts": {
    "generate:content-data": "node scripts/generate-content-data.js",
    "build:js": "node scripts/generate-content-data.js && vite build",
    "build:inline": "node scripts/inline.js",
    "build": "npm run build:js && npm run build:inline",
    "generate": "npm run build && node scripts/generate-static.js",
    "generate:blog": "node scripts/generate-blog.js",
    "generate:projects": "node scripts/generate-projects.js",
    "generate:paths": "node scripts/generate-paths.js",
    "generate:all": "npm run build && npm run generate:blog && npm run generate:projects && npm run generate:paths && node scripts/generate-static.js",
    "generate:diagrams": "node scripts/generate-diagrams.js",
    "generate:excalidraw": "node scripts/generate-excalidraw.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:og": "node scripts/generate-og-image.js",
    "deploy": "cd .. && git add -A && git diff --cached --quiet && echo 'nothing to commit' || git commit -m 'build: auto-deploy' && git push origin main",
    "dev": "chokidar '**/*.tsx' '**/*.jsx' 'tailwind.css' 'tailwind.config.js' 'scripts/inline.js' --ignore 'node_modules/**' --debounce 500 -c 'npm run build && npm run deploy'"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@tailwindcss/cli": "^4.2.1",
    "chokidar-cli": "^3.0.0",
    "google-auth-library": "^10.6.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "puppeteer": "^24.38.0",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0"
  }
}
